        new TaskData { TaskId = 5, TaskName = "Pour Footings", StartDate = new DateTime(2025, 01, 07), Duration = "4", Progress = 50, ParentId = 4, Predecessor = "4FS", BaselineStartDate = new DateTime(2025, 01, 07), BaselineEndDate = new DateTime(2025, 01, 11) },
        new TaskData { TaskId = 6, TaskName = "Cure Footings", StartDate = new DateTime(2025, 01, 11), Duration = "3", Progress = 20, ParentId = 4, Predecessor = "5FS", BaselineStartDate = new DateTime(2025, 01, 11), BaselineEndDate = new DateTime(2025, 01, 14) },

        // Phase 3: Structure
        new TaskData { TaskId = 7, TaskName = "Framing", StartDate = new DateTime(2025, 01, 14), Predecessor = "6FS", BaselineStartDate = new DateTime(2025, 01, 14), BaselineEndDate = new DateTime(2025, 01, 14) },
        new TaskData { TaskId = 8, TaskName = "Install Steel Frame", StartDate = new DateTime(2025, 01, 14), Duration = "6", Progress = 40, ParentId = 7, Predecessor = "", BaselineStartDate = new DateTime(2025, 01, 14), BaselineEndDate = new DateTime(2025, 01, 20) },
        new TaskData { TaskId = 9, TaskName = "Install Roof", StartDate = new DateTime(2025, 01, 20), Duration = "4", Progress = 30, ParentId = 7, Predecessor = "8SS-1d", BaselineStartDate = new DateTime(2025, 01, 20), BaselineEndDate = new DateTime(2025, 01, 24) },

        // Phase 4: Interior
        new TaskData { TaskId = 10, TaskName = "Interior Work", StartDate = new DateTime(2025, 01, 24), BaselineStartDate = new DateTime(2025, 01, 24), BaselineEndDate = new DateTime(2025, 01, 24) },
        new TaskData { TaskId = 11, TaskName = "Electrical Wiring", StartDate = new DateTime(2025, 01, 24), Duration = "5", Progress = 50, ParentId = 10, Predecessor = "", BaselineStartDate = new DateTime(2025, 01, 24), BaselineEndDate = new DateTime(2025, 01, 29) },
        new TaskData { TaskId = 12, TaskName = "Plumbing", StartDate = new DateTime(2025, 01, 24), Duration = "5", Progress = 50, ParentId = 10, Predecessor = "11SS", BaselineStartDate = new DateTime(2025, 01, 24), BaselineEndDate = new DateTime(2025, 01, 29) },
        new TaskData { TaskId = 13, TaskName = "HVAC Installation", StartDate = new DateTime(2025, 01, 25), Duration = "4", Progress = 30, ParentId = 10, Predecessor = "12SF", BaselineStartDate = new DateTime(2025, 01, 25), BaselineEndDate = new DateTime(2025, 01, 29) },

        // Final Phase
        new TaskData { TaskId = 14, TaskName = "Final Inspection", StartDate = new DateTime(2025, 02, 01), Duration = "2", Progress = 0, Predecessor = "13FF+2d", BaselineStartDate = new DateTime(2025, 02, 01), BaselineEndDate = new DateTime(2025, 02, 03) },
        new TaskData { TaskId = 15, TaskName = "Landscaping", StartDate = new DateTime(2025, 02, 04), Duration = "3", Progress = 0, Predecessor = "14FS", BaselineStartDate = new DateTime(2025, 02, 04), BaselineEndDate = new DateTime(2025, 02, 07) },
        new TaskData { TaskId = 16, TaskName = "Cleanup", StartDate = new DateTime(2025, 02, 06), Duration = "2", Progress = 0, Predecessor = "15SS", BaselineStartDate = new DateTime(2025, 02, 06), BaselineEndDate = new DateTime(2025, 02, 08) },
        new TaskData { TaskId = 17, TaskName = "Security System Setup", StartDate = new DateTime(2025, 02, 07), Duration = "2", Progress = 0, Predecessor = "16SF", BaselineStartDate = new DateTime(2025, 02, 07), BaselineEndDate = new DateTime(2025, 02, 09) },
